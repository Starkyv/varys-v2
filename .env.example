# Varys â€” environment variables
# =============================================================================
# You do NOT need a .env file for local dev â€” `pnpm dev` injects safe localhost
# defaults. Copy this to `.env` (at the repo root) to override any of them.
#
# How these are loaded: the API and worker load the repo-root `.env` at startup
# (dotenv), and values in `.env` WIN over the dev-script defaults. So just put a
# var here and restart `pnpm dev` for it to take effect. In production, set them
# through your process manager / container config (a `.env` there works too).
#
# Legend:  [required in prod]  must be set for any shared/deployed environment
#          [optional]          has a sensible default; override only if needed
# =============================================================================


# --- Core / infrastructure ---------------------------------------------------

# Postgres connection string (API + worker). Must match the docker-compose creds
# (user=varys, password=varys, db=varys, host port 5433) for the local stack.
# [optional locally Â· required in prod]
DATABASE_URL=postgres://varys:varys@localhost:5433/varys

# --- Artifact storage (run baseline/actual/diff PNGs + traces) ---------------
# Backend selector, SHARED by the API and the worker â€” they MUST agree.
#   local  (default) â†’ local filesystem at VARYS_STORAGE_DIR
#   azure            â†’ Azure Blob (needs the AZURE_STORAGE_* vars below)
# In Kubernetes pod disk is ephemeral and not shared between the API and worker
# pods, so set this to `azure` in any hosted deploy. [optional Â· `azure` in prod]
VARYS_STORAGE_DRIVER=local

# Local-FS root (used only when VARYS_STORAGE_DRIVER=local). Both processes must
# point at the SAME persistent, shared location. [optional]
VARYS_STORAGE_DIR=../../.varys-artifacts

# Azure Blob (used only when VARYS_STORAGE_DRIVER=azure). Auth is via a SAS token
# (the query string) â€” no account key is held by the process. The SAS needs
# read/add/create/write/delete on the container. The API streams blobs through its
# own authed /artifacts route, so no Azure-side CORS config is required.
# [required when driver=azure]
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_SAS_TOKEN=
# Optional blob-endpoint override; defaults to https://<account>.blob.core.windows.net
# AZURE_STORAGE_BLOB_ENDPOINT=

# Port the NestJS API listens on. The web dev server proxies to this. [optional]
PORT=4000

# Node environment. Affects framework behaviour (e.g. better-auth marks the session
# cookie Secure in production). Set to `production` when deployed. [optional]
NODE_ENV=development


# --- Auth: sessions (better-auth) --------------------------------------------

# Session signing key. A throwaway dev fallback is used if unset, so the local
# stack boots â€” but you MUST set a strong, secret value anywhere real.
# [required in prod]
BETTER_AUTH_SECRET=varys-dev-insecure-secret-change-me

# The public origin the browser reaches the auth routes (`/api/auth`) at, and the
# origin the Google OAuth redirect URI is built from. In dev the SPA is pinned to
# :5174 and proxies to the API, so the cookie + OAuth redirect are scoped to :5174.
# In prod, set this to the single ingress origin the web + API share.
# [required in prod]
BETTER_AUTH_URL=http://localhost:5174

# Comma list of browser origins allowed to call the auth endpoints (CSRF origin
# check) AND to make credentialed cross-origin API calls (the recorder extension).
# Add your deployed web origin in prod. [optional]
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5174,http://localhost:4000


# --- Auth: which sign-in methods are enabled ---------------------------------

# Comma list selecting enabled sign-in methods: `password`, `google`, or
# `password,google`. Default `password` (works with zero OAuth setup). The server
# is the source of truth; the login screen renders only what's enabled (it reads
# `GET /auth-config`). A lockout guard keeps email/password on if this would
# otherwise leave no usable method. [optional]
VARYS_AUTH_METHODS=password


# --- Auth: Google SSO (only when VARYS_AUTH_METHODS includes `google`) --------

# Google OAuth client credentials. Create a client in Google Cloud with the
# authorized redirect URI EXACTLY:  http://localhost:5174/api/auth/callback/google
# (note the path order: `callback/google`, not `google/callback`). Google stays OFF
# unless BOTH are set AND `google` is in VARYS_AUTH_METHODS.
# [required to use Google]
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Domain restriction for sign-in (env-driven). Comma list of permitted email
# domains; an empty value means no restriction. Default `datagenie.ai`. [optional]
VARYS_AUTH_ALLOWED_DOMAINS=datagenie.ai

# Scope of the domain restriction:
#   google = restrict only Google SSO (default; email/password is unrestricted)
#   all    = restrict every sign-up, email/password included
# [optional]
VARYS_AUTH_DOMAIN_SCOPE=google


# --- Claude test authoring (MCP) ---------------------------------------------

# General instructions for Claude when it authors tests through the MCP server â€”
# the "middleware prompt". Surfaced to Claude as the MCP `instructions` on connect
# and APPENDED to Varys's built-in authoring rules (which already tell Claude not
# to add network-idle waits by default). Use the inline var for a short prompt:
# VARYS_AUTHORING_INSTRUCTIONS="Always mask timestamps; prefer fullpage checkpoints."
# [optional]
# VARYS_AUTHORING_INSTRUCTIONS=

# â€¦or point at a file for a longer prompt (re-read on each connect, so edit + reconnect
# Claude â€” no API restart). A starter template lives at the repo root. Use an absolute
# path, or one relative to where the API process runs. [optional]
# VARYS_AUTHORING_INSTRUCTIONS_FILE=/absolute/path/to/authoring-instructions.md


# --- Web (Vite, build-time) --------------------------------------------------

# Base URL the SPA uses to reach the API. Empty = same-origin (the dev proxy /
# prod ingress), which is the normal setup. Set only for a split-origin deploy
# where the web and API are served from different origins. [optional]
# VITE_API_BASE=
