# Varys — environment variables
# =============================================================================
# You do NOT need a .env file for local dev. `pnpm dev` already injects safe
# localhost defaults (see each app's package.json "dev" script). This file
# documents every knob — copy it to `.env` to override locally, or use it as the
# checklist when configuring a deployment.
#
# How these are consumed: the dev scripts read them from the process environment
# (shell `${VAR:-default}` expansion), NOT via a dotenv loader. To apply a local
# `.env`, export it before starting:  `set -a; source .env; set +a; pnpm dev`
# In production, set them through your process manager / container config.
#
# Legend:  [required in prod]  must be set for any shared/deployed environment
#          [optional]          has a sensible default; override only if needed
# =============================================================================


# --- Core / infrastructure ---------------------------------------------------

# Postgres connection string (API + worker). Must match the docker-compose creds
# (user=varys, password=varys, db=varys, host port 5433) for the local stack.
# [optional locally · required in prod]
DATABASE_URL=postgres://varys:varys@localhost:5433/varys

# Where run artifacts (baseline/actual/diff PNGs, traces) are written. SHARED by
# the API and the worker — they must point at the same location. Local filesystem
# for now (Azure Blob / S3 adapters are a later slice). [optional]
VARYS_STORAGE_DIR=../../.varys-artifacts

# Port the NestJS API listens on. The web dev server proxies to this. [optional]
PORT=4000

# Node environment. Affects framework behaviour (e.g. better-auth marks the session
# cookie Secure in production). Set to `production` when deployed. [optional]
NODE_ENV=development


# --- Auth: sessions (better-auth) --------------------------------------------

# Session signing key. A throwaway dev fallback is used if unset, so the local
# stack boots — but you MUST set a strong, secret value anywhere real.
# [required in prod]
BETTER_AUTH_SECRET=varys-dev-insecure-secret-change-me

# The public origin the browser reaches the auth routes (`/api/auth`) at. In dev
# the SPA is served at :5200 and proxies to the API, so the cookie is scoped to
# :5200. In prod, set this to the single ingress origin the web + API share.
# [required in prod]
BETTER_AUTH_URL=http://localhost:5200

# Comma list of browser origins allowed to call the auth endpoints (CSRF origin
# check) AND to make credentialed cross-origin API calls (the recorder extension).
# Add your deployed web origin in prod. [optional]
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5200,http://localhost:4000


# --- Auth: which sign-in methods are enabled ---------------------------------

# Comma list selecting enabled sign-in methods: `password`, `google`, or
# `password,google`. Default `password` (works with zero OAuth setup). The server
# is the source of truth; the login screen renders only what's enabled (it reads
# `GET /auth-config`). A lockout guard keeps email/password on if this would
# otherwise leave no usable method. [optional]
VARYS_AUTH_METHODS=password


# --- Auth: Google SSO (only when VARYS_AUTH_METHODS includes `google`) --------

# Google OAuth client credentials. Create a client in Google Cloud with the
# authorized redirect URI:  <BETTER_AUTH_URL>/api/auth/callback/google
# Google stays OFF unless BOTH are set AND `google` is in VARYS_AUTH_METHODS.
# [required to use Google]
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Domain restriction for sign-in (env-driven). Comma list of permitted email
# domains; an empty value means no restriction. Default `datagenie.ai`. [optional]
VARYS_AUTH_ALLOWED_DOMAINS=datagenie.ai

# Scope of the domain restriction:
#   google = restrict only Google SSO (default; email/password is unrestricted)
#   all    = restrict every sign-up, email/password included
# [optional]
VARYS_AUTH_DOMAIN_SCOPE=google


# --- Web (Vite, build-time) --------------------------------------------------

# Base URL the SPA uses to reach the API. Empty = same-origin (the dev proxy /
# prod ingress), which is the normal setup. Set only for a split-origin deploy
# where the web and API are served from different origins. [optional]
# VITE_API_BASE=
