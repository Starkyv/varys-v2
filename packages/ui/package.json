{
  "name": "@varys/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Varys design system — tokens, themes, and primitive components (the 'Nexus' visual language).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": ["*.scss", "*.css"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.scss": "./src/index.scss",
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "sass": "^1.83.0",
    "typescript": "^5.7.3"
  }
}
