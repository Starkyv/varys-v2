{
  "name": "@varys/recorder",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dom": {
      "types": "./src/dom.ts",
      "default": "./src/dom.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@varys/step-schema": "workspace:*"
  },
  "devDependencies": {
    "@varys/capture": "workspace:*",
    "@varys/fixture-app": "workspace:*",
    "playwright": "^1.50.1",
    "vitest": "^3.0.5"
  }
}
