{
  "name": "@varys/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "DATABASE_URL=${DATABASE_URL:-postgres://varys:varys@localhost:5433/varys} VARYS_STORAGE_DIR=${VARYS_STORAGE_DIR:-../../.varys-artifacts} PORT=${PORT:-4000} BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET:-varys-dev-insecure-secret-change-me} BETTER_AUTH_URL=${BETTER_AUTH_URL:-http://localhost:5174} tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "for f in test/*.spec.ts; do echo \"--- $f ---\"; vitest run \"$f\" || exit 1; done"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.6",
    "@nestjs/core": "^11.0.6",
    "@nestjs/platform-express": "^11.0.6",
    "@varys/capture": "workspace:*",
    "@varys/db": "workspace:*",
    "@varys/diff-engine": "workspace:*",
    "@varys/judge-engine": "workspace:*",
    "@varys/queue": "workspace:*",
    "@varys/recorder": "workspace:*",
    "@varys/review-contract": "workspace:*",
    "@varys/step-schema": "workspace:*",
    "@varys/storage-adapter": "workspace:*",
    "better-auth": "^1.6.19",
    "cron-parser": "^4.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.39.1",
    "pg": "^8.13.1",
    "playwright-core": "^1.50.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.6",
    "@swc/core": "^1.10.16",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.2",
    "@varys/fixture-app": "workspace:*",
    "@varys/runner": "workspace:*",
    "playwright": "^1.50.1",
    "supertest": "^7.0.0",
    "testcontainers": "^10.18.0",
    "tsx": "^4.19.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.5"
  }
}
