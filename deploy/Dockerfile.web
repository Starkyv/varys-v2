# Web SPA: build the Vite bundle, then serve the static output with nginx.
#
# The SPA calls the API same-origin (relative paths like /runs, /artifacts,
# /api/auth) — the Ingress routes those prefixes to the API Service and everything
# else here. So VITE_API_BASE stays empty for the normal single-origin deploy; set
# it (build arg) only for a split-origin setup.
FROM node:22-bookworm-slim AS build

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
WORKDIR /app
RUN corepack enable

COPY . .
RUN pnpm install --frozen-lockfile

ARG VITE_API_BASE=""
ENV VITE_API_BASE=$VITE_API_BASE
RUN pnpm --filter @varys/web build

# Build the production-pointed recorder extension and expose it as a stable static
# download under the SPA (served by nginx below; the in-app "Browser extension" page
# links to /downloads/varys-extension-chrome.zip). The API URL is baked into the
# extension at build time, so point it at the same origin this web bundle serves.
ARG WXT_API_BASE=https://varys.datagenie.ai
RUN WXT_API_BASE="$WXT_API_BASE" pnpm --filter @varys/extension exec wxt zip \
 && mkdir -p apps/web/dist/downloads \
 && cp apps/extension/.output/*-chrome.zip apps/web/dist/downloads/varys-extension-chrome.zip

# Unprivileged nginx (listens on 8080, runs as a non-root user).
FROM nginxinc/nginx-unprivileged:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
EXPOSE 8080
